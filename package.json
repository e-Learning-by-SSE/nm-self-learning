{
	"name": "self-learning",
	"version": "unstable",
	"license": "MIT",
	"scripts": {
		"postinstall": "prisma generate --no-hints",
		"start": "concurrently \"nx serve site\" \"nx serve cron-service\"  \"NODE_PATH=dist/libs nx serve worker-service\"",
		"start:dev": "concurrently \"nx serve site\" \"npx prisma studio --browser none\"",
		"prod:site": "cd dist/apps/site && DOTENV_CONFIG_PATH=../../../.env node -r dotenv/config ../../../node_modules/next/dist/bin/next start .",
		"prod:cron": "DOTENV_CONFIG_PATH=.env node -r dotenv/config dist/apps/cron-service/main.js",
		"prod:worker": "DOTENV_CONFIG_PATH=.env node -r dotenv/config dist/apps/worker-service/main.js",
		"start:standalone": "concurrently \"npm run prod:site\" \"npm run prod:cron\" \"npm run prod:worker\"",
		"start:prod": "npm run migrate && npm run start:standalone",
		"start:demo": "npm run seed && npm run start:standalone",
		"reset:cromadb": "npx tsx --tsconfig tsconfig.base.json scripts/reset-chroma.ts",
		"cypress": "cypress open --project=apps/site-e2e",
		"jest": "env TZ='Europe/Berlin' jest",
		"format:check": "nx format:check --files '{apps,libs}/**/*.{ts,tsx}'",
		"format:write": "nx format:write --files '{apps,libs}/**/*.{ts,tsx}'",
		"prebuild": "npm run prisma generate --no-hints",
		"build": "nx run-many --target=build --projects=site,cron-service,worker-service",
		"test": "env TZ='Europe/Berlin' nx run-many --target=test --all --parallel --maxParallel=4",
		"test:pr": "nx affected --base origin/master -t lint build test",
		"test:ci": "env TZ='Europe/Berlin' nx run-many --target=test --all --parallel --maxParallel=4 --skip-nx-cache --runInBand",
		"posttest:pr": "echo 'If this fails, run the failed task to see errors.",
		"test:migrate": "prisma db execute --file=scripts/reset.sql --schema libs/data-access/database/prisma/schema && npm run migrate",
		"prisma": "prisma",
		"seed": "prisma generate && prisma db push --accept-data-loss && prisma db seed",
		"migrate": "tsx libs/data-access/database/prisma/deploy-migrations.ts"
	},
	"private": true,
